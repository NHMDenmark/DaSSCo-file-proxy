        <mxCell id="e_invalid" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#C62828;fontSize=12;fontColor=#B71C1C;" edge="1" parent="1" source="valid_decision" target="bad_request">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_valid" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#2E7D32;fontSize=12;fontColor=#1B5E20;" edge="1" parent="1" source="valid_decision" target="fetch_assets">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_fetch_403" value="403" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#C62828;fontSize=12;fontColor=#B71C1C;" edge="1" parent="1" source="fetch_assets" target="asset_403">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_fetch_non2xx" value="other non-2xx" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#C62828;fontSize=12;fontColor=#B71C1C;" edge="1" parent="1" source="fetch_assets" target="asset_non2xx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_fetch_exception" value="exception" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#C62828;fontSize=12;fontColor=#B71C1C;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="fetch_assets" target="asset_exception">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1145" y="917.5" />
              <mxPoint x="1145" y="1177.5" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e_fetch_metadata" value="2xx" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#2E7D32;fontSize=12;fontColor=#1B5E20;" edge="1" parent="1" source="fetch_assets" target="metadata">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_metadata_files" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#455A64;fontSize=12;fontColor=#263238;" edge="1" parent="1" source="metadata" target="get_files">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_files_temp" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#455A64;fontSize=12;fontColor=#263238;" edge="1" parent="1" source="get_files" target="temp_file">
          <mxGeometry relative="1" as="geometry" />
