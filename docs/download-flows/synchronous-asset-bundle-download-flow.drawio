        <mxCell id="e_temp_zip" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#455A64;fontSize=12;fontColor=#263238;" edge="1" parent="1" source="temp_file" target="zip">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_zip_error" value="IOException" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#C62828;fontSize=12;fontColor=#B71C1C;" edge="1" parent="1" source="zip" target="zip_error">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_zip_range" value="ZIP created" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#2E7D32;fontSize=12;fontColor=#1B5E20;" edge="1" parent="1" source="zip" target="range">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_range_decision" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#455A64;fontSize=12;fontColor=#263238;" edge="1" parent="1" source="range" target="range_decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_no_range" value="Absent" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#2E7D32;fontSize=12;fontColor=#1B5E20;" edge="1" parent="1" source="range_decision" target="full_response">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_valid_range" value="Valid" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#2E7D32;fontSize=12;fontColor=#1B5E20;" edge="1" parent="1" source="range_decision" target="partial_response">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_invalid_range" value="Invalid" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#C62828;fontSize=12;fontColor=#B71C1C;" edge="1" parent="1" source="range_decision" target="range_error">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_full_cleanup" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#455A64;fontSize=12;fontColor=#263238;" edge="1" parent="1" source="full_response" target="cleanup">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_partial_cleanup" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#455A64;fontSize=12;fontColor=#263238;" edge="1" parent="1" source="partial_response" target="cleanup">
          <mxGeometry relative="1" as="geometry" />
